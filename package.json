{
  "name": "@uswap/browser-extension",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "description": "uSwap browser extension (Chrome + Firefox MV3) — side panel hosting the uSwap app, and the window.peer payment-capture contract for the fiat onramp. Single source, dual target via EXT_TARGET.",
  "scripts": {
    "dev": "vite",
    "dev:firefox": "EXT_TARGET=firefox vite",
    "build": "vite build",
    "build:firefox": "EXT_TARGET=firefox vite build",
    "build:all": "bun run build && bun run build:firefox",
    "package": "bun scripts/zip.ts",
    "package:firefox": "web-ext build --source-dir dist/firefox --artifacts-dir dist/firefox-artifacts --overwrite-dest",
    "lint:firefox": "web-ext lint --source-dir dist/firefox",
    "run:firefox": "web-ext run --source-dir dist/firefox",
    "test": "bun test test/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@zkp2p/sdk": "^0.5.0",
    "jsonpath-plus": "^10.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.5.0",
    "@types/chrome": "^0.0.326",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "bun-types": "^1.3.11",
    "typescript": "^5.6.0",
    "vite": "^6.3.5",
    "web-ext": "^10.4.0"
  }
}
